# Copia questo file in .env e compila i valori reali
# MAI committare .env su GitHub

# Supabase (visibili nel dashboard: Settings > API)
VITE_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chiave AES-256 per cifrare le API key nel DB
# Generala UNA SOLA VOLTA con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Non cambiarla mai dopo il primo deploy!
ENCRYPTION_SECRET=la_tua_chiave_hex_di_64_caratteri

# Unsplash (immagini copertina materie) — ottieni su unsplash.com/developers
UNSPLASH_ACCESS_KEY=la_tua_chiave_unsplash

# Web Push — VAPID keys (genera UNA SOLA VOLTA con:
#   node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log(k)")
# VITE_VAPID_PUBLIC_KEY è anche esposto al client (prefix VITE_)
VITE_VAPID_PUBLIC_KEY=BCoJhGVrqAVVeHiKiGcilPRrMoIx68_MjU7epBQGx_aiR6pJLcq8HEE5w0_Hvhs4SaiNhoFbeSK_PJ2RmdNHlUo
VAPID_PUBLIC_KEY=BCoJhGVrqAVVeHiKiGcilPRrMoIx68_MjU7epBQGx_aiR6pJLcq8HEE5w0_Hvhs4SaiNhoFbeSK_PJ2RmdNHlUo
VAPID_PRIVATE_KEY=oXa1wQo1lhQcLFQ1QisP0HKN4M-Sr8dTgrvNYiEdOYE
VAPID_SUBJECT=mailto:riccarspiga@gmail.com

# Token segreto per proteggere il cron endpoint (/api/cron/ripasso-notify)
# Su Vercel Cron è iniettato in header Authorization: Bearer <CRON_SECRET>
CRON_SECRET=genera_un_token_random_di_32_caratteri
